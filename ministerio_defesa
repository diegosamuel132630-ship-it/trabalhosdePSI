from soldados import soldados, buscar_soldado_por_id
from utils import paises

missoes = []
next_missao_id = 1


def relatorio_geral():
    total = len(soldados)
    por_pais = {p: len(dados["soldados"]) for p, dados in paises.items()}

    return 200, {
        "total_soldados": total,
        "soldados_por_pais": por_pais
    }


def transferir_soldado(soldado_id, novo_pais):
    if novo_pais not in paises:
        return 404, "País inválido"

    code, soldado = buscar_soldado_por_id(soldado_id)
    if code != 200:
        return 404, "Soldado não encontrado"

    antigo = soldado["pais"]

    if antigo == novo_pais:
        return 400, "Já está nesse país"

    if soldado in paises[antigo]["soldados"]:
        paises[antigo]["soldados"].remove(soldado)

    paises[novo_pais]["soldados"].append(soldado)
    soldado["pais"] = novo_pais

    return 200, soldado


def criar_missao(nome, pais, lista_ids):
    global next_missao_id

    if not nome.strip():
        return 400, "Nome inválido"

    if pais not in paises:
        return 404, "País inválido"

    for sid in lista_ids:
        code, _ = buscar_soldado_por_id(sid)
        if code != 200:
            return 404, f"Soldado {sid} não existe"

    missao = {
        "id": next_missao_id,
        "nome": nome.strip(),
        "pais": pais,
        "soldados": lista_ids
    }

    missoes.append(missao)
    next_missao_id += 1

    return 201, missao


def listar_missoes():
    return 200, missoes


def ranking_paises():
    ranking = sorted(
        [(p, len(d["soldados"])) for p, d in paises.items()],
        key=lambda x: x[1],
        reverse=True
    )
    return 200, ranking
